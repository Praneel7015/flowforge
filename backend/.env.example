# ─────────────────────────────────────────────────────────────
# FlowForge Configuration
# Platform-independent CI/CD automation with multi-AI support
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# DEFAULT PROVIDERS
# Used when not specified in API request
# ─────────────────────────────────────────────────────────────
DEFAULT_AI_PROVIDER=featherless
# Options: featherless, anthropic, gemini, openai, ollama

DEFAULT_CICD_PLATFORM=gitlab
# Options: gitlab, github, jenkins, circleci

# ─────────────────────────────────────────────────────────────
# AI PROVIDERS
# Configure at least one AI provider to enable AI features
# ─────────────────────────────────────────────────────────────

# Anthropic (Claude)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-5
# Models: claude-opus-4-5, claude-sonnet-4-5, claude-3-haiku-20240307

# Google Gemini
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro
# Models: gemini-1.5-pro, gemini-1.5-flash, gemini-pro

# OpenAI (GPT-4)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4-turbo
# Models: gpt-4-turbo, gpt-4o, gpt-3.5-turbo

# Featherless AI (OpenAI-compatible)
# Endpoint: https://api.featherless.ai/v1
# Hackathon note: organizers shared code LOVHACK26 for Feather Premium access.
FEATHERLESS_API_KEY=your_featherless_api_key
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-Coder-1.5B-Instruct

# Ollama (Local LLM - no API key required)
# Install Ollama: https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Models: llama3, mistral, codellama, or any model you have installed

# n8n Webhook (Hackathon sponsor integration)
# If set, pipeline chat requests are sent to this webhook.
# Example: https://your-n8n-domain/webhook-test/flowforge
N8N_CHAT_WEBHOOK_URL=
# Optional custom auth header + token for securing the webhook.
N8N_WEBHOOK_AUTH_HEADER=X-FlowForge-Token
N8N_WEBHOOK_AUTH_TOKEN=
# Optional timeout for webhook calls.
N8N_CHAT_TIMEOUT_MS=30000

# ─────────────────────────────────────────────────────────────
# GIT PLATFORM INTEGRATION (Optional)
# For webhook handling and auto-remediation features
# ─────────────────────────────────────────────────────────────

# GitLab
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_PROJECT_ID=your_project_id
GITLAB_WEBHOOK_SECRET=your_webhook_secret

# GitHub (Future)
# GITHUB_TOKEN=ghp_your_github_token
# GITHUB_OWNER=your_username_or_org
# GITHUB_REPO=your_repo_name
# GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Bitbucket (Future)
# BITBUCKET_USERNAME=your_username
# BITBUCKET_APP_PASSWORD=your_app_password
# BITBUCKET_WORKSPACE=your_workspace
# BITBUCKET_REPO=your_repo

# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3001

# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL=https://highcortisol.xyz,https://www.highcortisol.xyz
